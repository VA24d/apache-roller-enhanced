## $model here is a PageModel
## $entry here is a WeblogEntryWrapper
<!-- _day -->
<div class="dayBox">

    <div class="dayTitle">
       $utils.formatDate($day, $text.get("macro.weblog.date.toStringFormat"))
    </div>

    #foreach( $entry in $entries )
      <div class="entryBox">
        <a name="$utils.encode($entry.anchor)" id="$utils.encode($entry.anchor)"></a>
        <p class="entryTitle">$entry.title</p>
        ## Render pipeline metadata badges (sentiment + reading time) from searchDescription
        #set($entryMeta = $entry.searchDescription)
        #if($entryMeta && $entryMeta != "")
        <div class="entry-badges" style="margin-bottom:8px;">
            #if($entryMeta.contains("Sentiment: Positive"))
                <span class="sentiment-badge" style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:0.85em;background-color:#dff0d8;color:#3c763d;margin-right:6px;">Sentiment: Positive</span>
            #elseif($entryMeta.contains("Sentiment: Negative"))
                <span class="sentiment-badge" style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:0.85em;background-color:#f2dede;color:#a94442;margin-right:6px;">Sentiment: Negative</span>
            #elseif($entryMeta.contains("Sentiment: Neutral"))
                <span class="sentiment-badge" style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:0.85em;background-color:#f5f5f5;color:#777;margin-right:6px;">Sentiment: Neutral</span>
            #end
            #if($entryMeta.contains("min read"))
                #foreach($metaPart in $entryMeta.split('\|'))
                    #set($trimmedPart = $metaPart.trim())
                    #if($trimmedPart.endsWith("min read"))
                        <span class="reading-time" style="display:inline-block;padding:2px 10px;border-radius:4px;font-size:0.85em;background-color:#d9edf7;color:#31708f;margin-right:6px;">&#128337; $trimmedPart</span>
                    #end
                #end
            #end
        </div>
        #end
        <p class="entryContent">
            #if($model.permalink)
                $entry.displayContent
            #else
                $entry.displayContent($url.entry($entry.anchor))
            #end
        </p>
        <p class="entryInfo">
            Posted at <a href="$url.entry($entry.anchor)">$utils.formatDate($entry.pubTime, $text.get("macro.weblog.datetime.toStringFormat"))</a>
            by $entry.creator.screenName in <span class="category">$entry.category.name</span> &nbsp;|&nbsp;
            #if ($utils.isUserAuthorizedToAuthor($entry.website))
                <a href="$url.editEntry($entry.anchor)">$text.get("generic.edit")</a> &nbsp;|&nbsp;
            #end
            #set($commentCount = $entry.commentCount)
            #if($entry.commentsStillAllowed || $commentCount > 0)
                #set($link = "$url.comments($entry.anchor)" )
                <a href="$link" class="commentsLink">$text.get("macro.weblog.comments") [$commentCount]</a>
            #end
        </p>
        #showTrackbackAutodiscovery($entry)
      </div>
    #end

</div>
