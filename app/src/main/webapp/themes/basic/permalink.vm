<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>$model.weblogEntry.title : $model.weblog.name</title>
    #showAutodiscoveryLinks($model.weblog)
    #showAnalyticsTrackingCode($model.weblog)
    <link rel="stylesheet" href="$model.weblog.stylesheet">
    #showMetaDescription()
</head>
<!-- permalink -->
<body>
<div id="id_permalink" class="content_wrapper">
  <div class="content">
    <h1 class="weblogName">$utils.escapeHTML($model.weblog.name)</h1>

        <center>
        #showWeblogCategoryLinksList()
        </center>

        ## show next/previous paging controls
        #set($pager = $model.getWeblogEntriesPager()) 
        <div class="next-previous">
            #showNextPrevEntriesControl($pager)
        </div>

        ## show entry
        #showWeblogEntriesPager($pager)

        ## Star entry button — shown to any logged-in user
        #if($utils.isUserAuthenticated() && $model.weblogEntry)
        <div style="margin:10px 0;">
        #if($utils.isEntryStarred($model.weblogEntry.id))
            <form method="post" action="$url.site/roller-ui/starEntry!unstar" style="display:inline;">
                <input type="hidden" name="entryId" value="$model.weblogEntry.id"/>
                <button type="submit"
                    style="cursor:pointer;background:none;border:1px solid #c00;border-radius:4px;padding:4px 10px;color:#c00;font-size:0.95em;">
                    &#9733; Unstar this post
                </button>
            </form>
        #else
            <form method="post" action="$url.site/roller-ui/starEntry!star" style="display:inline;">
                <input type="hidden" name="entryId" value="$model.weblogEntry.id"/>
                <button type="submit"
                    style="cursor:pointer;background:none;border:1px solid #c8860a;border-radius:4px;padding:4px 10px;color:#c8860a;font-size:0.95em;">
                    &#9734; Star this post
                </button>
            </form>
        #end
        </div>
        #end

        ## show comments and comment form
        #showWeblogEntryComments($model.weblogEntry)
        #showWeblogEntryCommentForm($model.weblogEntry)

  </div>
</div>

<div class="rightbar_wrapper">
  <div class="rightbar">
    #includeTemplate($model.weblog "sidebar")
  </div>
</div>

</body>
</html>
